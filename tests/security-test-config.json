{
  "ci_cd": {
    "enabled": true,
    "run_on": ["push", "pull_request", "schedule"],
    "branches": ["main", "develop", "release/*"],
    "schedule": "0 2 * * *"
  },
  
  "security_thresholds": {
    "min_security_score": 80,
    "max_critical_vulnerabilities": 0,
    "max_high_vulnerabilities": 2,
    "max_medium_vulnerabilities": 5,
    "fail_on_critical": true,
    "fail_on_high": false,
    "warn_on_medium": true
  },
  
  "required_tests": {
    "always_run": [
      "sql_injection",
      "xss",
      "authentication",
      "input_validation"
    ],
    "run_on_schedule": [
      "rate_limiting",
      "error_handling",
      "concurrency"
    ]
  },
  
  "endpoints_to_test": {
    "authentication": [
      "/graphql (login)",
      "/graphql (register)",
      "/graphql (logout)"
    ],
    "user_data": [
      "/graphql (getUserProfile)",
      "/graphql (updateProfile)"
    ],
    "public": [
      "/graphql (contactus)",
      "/graphql (getPosts)"
    ]
  },
  
  "payload_configuration": {
    "sql_injection": {
      "payload_count": 15,
      "types": ["basic", "union", "error", "blind", "time"],
      "severity": "critical"
    },
    "xss": {
      "payload_count": 10,
      "types": ["script", "event", "uri", "svg", "iframe"],
      "severity": "high"
    },
    "authentication": {
      "test_cases": 8,
      "types": ["valid", "invalid", "bypass", "token_tamper"],
      "severity": "high"
    }
  },
  
  "reporting": {
    "formats": ["json", "junit", "markdown", "html"],
    "artifacts": [
      "security-test-report.json",
      "executive-security-summary.json",
      "security-test-results.xml",
      "SECURITY_SUMMARY.md"
    ],
    "retention_days": 30,
    "notify_on_failure": true,
    "notify_channels": ["slack", "email", "github"]
  },
  
  "integration": {
    "github_actions": {
      "workflow_file": ".github/workflows/security.yml",
      "job_name": "security-tests",
      "runs_on": "ubuntu-latest"
    },
    "gitlab_ci": {
      "stage": "security",
      "image": "python:3.11",
      "artifacts": true
    },
    "jenkins": {
      "stage": "Security Testing",
      "agent": "any",
      "archive_artifacts": true
    }
  },
  
  "notifications": {
    "slack": {
      "channel": "#security-alerts",
      "on_failure": true,
      "on_success": false,
      "include_report": true
    },
    "email": {
      "recipients": ["security-team@example.com", "cto@example.com"],
      "on_critical": true,
      "daily_summary": true
    },
    "github": {
      "comment_on_pr": true,
      "status_check": true,
      "require_passing": true
    }
  },
  
  "remediation": {
    "auto_create_issues": true,
    "issue_labels": ["security", "bug", "priority-high"],
    "assign_to": "security-team",
    "due_days": 7,
    "escalation_days": 3
  },
  
  "monitoring": {
    "trend_analysis": true,
    "score_history": 90,
    "alert_on_decline": true,
    "decline_threshold": 10,
    "weekly_report": true
  },
  
  "version": "1.0.0",
  "last_updated": "2026-04-09",
  "maintainer": "security-team@peernetwork.com"
}